<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryProject.MAUI.Views.BookDetailPage"
             Title="{Binding Title}" 
             BackgroundColor="#FEF5F1">

    <ScrollView Padding="20">
        
        <VerticalStackLayout Spacing="20">

            <Frame HeightRequest="300" CornerRadius="15" Padding="0" BackgroundColor="#F8EDEB" BorderColor="Transparent" IsClippedToBounds="True">
                <Grid>
                    <Label Text="📷" FontSize="70" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#A3918E"/>
                    <Image Source="{Binding ImageUrl}" Aspect="AspectFit" />
                </Grid>
            </Frame>

            <Frame BackgroundColor="#FFFFFF" BorderColor="#FBC4AB" CornerRadius="20" Padding="25" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Назва книги:" FontSize="13" TextColor="#A3918E"/>
                    <Label Text="{Binding BookTitle}" FontSize="24" FontAttributes="Bold" TextColor="#6D5953"/>

                    <BoxView HeightRequest="1" Color="#FEF5F1" Margin="0,10"/>

                    <Label Text="Автор:" FontSize="13" TextColor="#A3918E"/>
                    <Label Text="{Binding AuthorName}" FontSize="18" TextColor="#6D5953"/>

                    <Label Text="ISBN:" FontSize="13" TextColor="#A3918E"/>
                    <Label Text="{Binding Isbn}" FontSize="16" TextColor="#6D5953"/>

                    <Label Text="Ціна:" FontSize="13" TextColor="#A3918E" Margin="0,10,0,0"/>
                    <Label Text="{Binding Price, StringFormat='{0} грн'}" FontSize="22" FontAttributes="Bold" TextColor="#F8AD9D"/>

                    <BoxView HeightRequest="1" Color="#FEF5F1" Margin="0,15,0,10"/>
                    <Label Text="Про книгу:" FontSize="16" FontAttributes="Bold" TextColor="#6D5953"/>
                    <Label Text="{Binding Description}" FontSize="14" TextColor="#6D5953" LineBreakMode="WordWrap" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Редагувати" Command="{Binding EditCommand}" IsVisible="{Binding IsAdmin}"
                BackgroundColor="#FBC4AB" TextColor="#6D5953" CornerRadius="12" HeightRequest="50" FontAttributes="Bold" Margin="0,20,0,0"/>

            <Button Text="Видалити" Command="{Binding DeleteCommand}" IsVisible="{Binding IsAdmin}"
                BackgroundColor="#E5989B" TextColor="#FFFFFF" CornerRadius="12" HeightRequest="50" FontAttributes="Bold" Margin="0,10,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>