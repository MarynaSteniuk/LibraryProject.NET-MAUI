<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryProject.MAUI.Views.AuthorFormPage"
             Title="{Binding Title}"
             BackgroundColor="#FEF5F1">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Label Text="Ім'я автора" TextColor="#6D5953" FontAttributes="Bold" Margin="0,0,0,-5"/>
            <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Джоан Роулінг" BackgroundColor="#FFFFFF"/>

            <Label Text="Національність" TextColor="#6D5953" FontAttributes="Bold" Margin="0,10,0,-5"/>
            <Entry Text="{Binding Nationality, Mode=TwoWay}" Placeholder="Британка" BackgroundColor="#FFFFFF"/>

            
            <Label Text="Дата народження" TextColor="#6D5953" FontAttributes="Bold" Margin="0,10,0,-5"/>
            <DatePicker Date="{Binding BirthDate, Mode=TwoWay}" MinimumDate="01/01/1800" MaximumDate="12/31/2100" BackgroundColor="#FFFFFF"/>

            <Button Text="Зберегти" Command="{Binding SaveCommand}" IsEnabled="{Binding IsNotBusy}" 
                BackgroundColor="#F8AD9D" TextColor="#FFFFFF" CornerRadius="12" HeightRequest="55" FontAttributes="Bold" Margin="0,20,0,0"/>

            <Button Text="Скасувати" Command="{Binding CancelCommand}" 
                BackgroundColor="#F8EDEB" TextColor="#A3918E" CornerRadius="12" HeightRequest="55" FontAttributes="Bold"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>