<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryProject.MAUI.Views.BooksPage"
             Title="{Binding Title}"
             BackgroundColor="#FEF5F1">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Додати" Command="{Binding GoToAddCommand}" />
    </ContentPage.ToolbarItems>

    <Grid Padding="15">
        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}" 
                           Color="#FBC4AB" 
                           HorizontalOptions="Center" VerticalOptions="Center" ZIndex="1"/>

        <CollectionView ItemsSource="{Binding Books}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,15" Padding="15" CornerRadius="20" 
                           BackgroundColor="#FFFFFF" BorderColor="#FBC4AB" HasShadow="True">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToDetailCommand}" 
                                                  CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" TextColor="#6D5953"/>
                            <Label Text="{Binding Isbn, StringFormat='ISBN: {0}'}" FontSize="14" TextColor="#A3918E" Margin="0,5,0,0"/>
                            <Label Text="{Binding Price, StringFormat='{0} грн'}" FontSize="17" TextColor="#F8AD9D" FontAttributes="Bold" HorizontalOptions="End"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>