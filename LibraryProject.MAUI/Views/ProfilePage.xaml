<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryProject.MAUI.Views.ProfilePage"
             Title="{Binding Title}"
             BackgroundColor="#FEF5F1">

    <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

        <Frame BackgroundColor="#F8AD9D" WidthRequest="120" HeightRequest="120" CornerRadius="60" 
               HorizontalOptions="Center" HasShadow="True" BorderColor="Transparent" Padding="0">
            <Label Text="👤" FontSize="60" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#FFFFFF"/>
        </Frame>

        <Label Text="Ваш акаунт" FontSize="24" FontAttributes="Bold" TextColor="#6D5953" HorizontalOptions="Center"/>

        <Frame BackgroundColor="#FFFFFF" BorderColor="#FBC4AB" CornerRadius="15" Padding="20" HasShadow="False">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="Поточний Email:" FontSize="14" TextColor="#A3918E" HorizontalOptions="Center"/>
                <Label Text="{Binding UserEmail}" FontSize="18" FontAttributes="Bold" TextColor="#6D5953" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Frame>

        <Button Text="Вийти з акаунту" Command="{Binding LogoutCommand}"
                BackgroundColor="#E5989B" TextColor="#FFFFFF" CornerRadius="12" HeightRequest="55" FontAttributes="Bold" Margin="0,20,0,0"/>

    </VerticalStackLayout>
</ContentPage>