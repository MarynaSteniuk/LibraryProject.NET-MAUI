<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LibraryProject.MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:LibraryProject.MAUI.Views"
    Shell.FlyoutBehavior="Flyout">

    <ShellItem FlyoutItemIsVisible="False">
        <ShellContent Route="LoginPage" ContentTemplate="{DataTemplate local:LoginPage}" />
    </ShellItem>

    <FlyoutItem Title="Каталог Книг">
        <ShellContent Route="BooksPage" ContentTemplate="{DataTemplate local:BooksPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Автори">
        <ShellContent Route="AuthorsPage" ContentTemplate="{DataTemplate local:AuthorsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Мій профіль">
        <ShellContent Route="ProfilePage" ContentTemplate="{DataTemplate local:ProfilePage}" />
    </FlyoutItem>

</Shell>