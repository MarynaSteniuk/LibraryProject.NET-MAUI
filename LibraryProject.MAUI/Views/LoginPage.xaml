<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryProject.MAUI.Views.LoginPage"
             BackgroundColor="#FEF5F1"
             Shell.NavBarIsVisible="False">


    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Label Text="Вітаємо!" FontSize="32" FontAttributes="Bold" TextColor="#6D5953" HorizontalOptions="Center" Margin="0,0,0,20"/>

        <Frame BackgroundColor="#FFFFFF" BorderColor="#FBC4AB" CornerRadius="15" Padding="0" HasShadow="False">
            <Entry Text="{Binding Email}" Placeholder="Email" Keyboard="Email" TextColor="#6D5953" Margin="15,5"/>
        </Frame>

        <Frame BackgroundColor="#FFFFFF" BorderColor="#FBC4AB" CornerRadius="15" Padding="0" HasShadow="False">
            <Entry Text="{Binding Password}" Placeholder="Пароль" IsPassword="True" TextColor="#6D5953" Margin="15,5"/>
        </Frame>

        <Button Text="Увійти" Command="{Binding LoginCommand}" IsEnabled="{Binding IsNotBusy}"
                BackgroundColor="#F8AD9D" TextColor="#FFFFFF" CornerRadius="12" HeightRequest="55" FontAttributes="Bold" Margin="0,15,0,0"/>

        <Button Text="Ще немає акаунта? Зареєструватися" 
                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToRegisterCommand}" 
                BackgroundColor="Transparent" TextColor="#A3918E" FontAttributes="Bold" Margin="0,10,0,0"/>

        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#FBC4AB" HorizontalOptions="Center"/>

    </VerticalStackLayout>
</ContentPage>